# Controls what `gcloud run deploy --source` uploads as the build context.
# Explicit allowlist style: ignore everything sensitive / unneeded.

# Never upload credentials — they are injected via Secret Manager.
.streamlit/
secrets.toml
secrets.toml.example
todc-marketing-*.json
*service-account*.json
.env
.env.*

# Not needed in the API container.
streamlit_app.py
scripts/
README.md
__pycache__/
*.pyc
