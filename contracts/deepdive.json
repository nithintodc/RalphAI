{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeepDiveAgent",
  "description": "Analyzes ingested performance data and produces structured insights.",
  "type": "object",
  "properties": {
    "input": {
      "type": "object",
      "required": ["operator_id", "data"],
      "properties": {
        "operator_id": { "type": "string", "minLength": 1 },
        "data": { "type": "object" }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "required": ["operator_id", "insights", "problems", "opportunities"],
      "properties": {
        "operator_id": { "type": "string" },
        "insights": { "type": "array", "items": { "type": "string" } },
        "problems": { "type": "array", "items": { "type": "string" } },
        "opportunities": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
