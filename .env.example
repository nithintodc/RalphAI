# Local secrets — gitignored. Loaded by streamlit_app/export_api.py.
# =============================================================================
# DoorDash Browser Automation — Environment Variables
# Copy this file to .env and fill in your values
# --- DoorDash Credentials ---
# --- Browser Use API (LLM-driven browser control) ---
# --- Browser Connection (pick ONE, in priority order) ---
# Option 1: Remote headless Chrome via CDP (GCP VM, Docker, Browserless.io)
# LOCAL_BROWSER_CDP_URL=http://localhost:9222
# Option 2: Multilogin anti-detect browser (persistent profiles + fingerprinting)
# MULTILOGIN_CDP_URL=ws://127.0.0.1:XXXXX/devtools/browser/...
# Option 3: No env var = use local Chrome executable (macOS laptop default)
# --- Google Sheets Push ---
# GCP_CREDENTIALS_PATH=/path/to/service-account.json  (or use todc-marketing-*.json in project root)
# --- Slack Notifications ---
# --- Campaign Tuning ---
LOG_LEVEL=INFO
CONTRACTS_DIR=
REQUIRE_HUMAN_APPROVAL=false
MIN_CONFIDENCE=0.0
MAX_BUDGET_CENTS=
TODC_DATA_DIR=
REVIEW_DELAY_DAYS=7
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_ID=
AIRTABLE_VIEW_ID=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
REDIS_URL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GCP_PROJECT=
GCP_REGION=
DOORDASH_EMAIL=
DOORDASH_PASSWORD=
MARKETING_CAMPAIGN_DEBUG=1
USE_LOCAL_BROWSER=true
DOORDASH_PARALLEL_CAMPAIGNS_BY_STORE=true
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/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
GOOGLE_SPREADSHEET_ID=
CHROME_USER_DATA_DIR=
BROWSER_USE_API_KEY=
